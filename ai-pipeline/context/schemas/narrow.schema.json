{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pipeline.local/context/schemas/narrow.schema.json",
  "title": "Narrow Context Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "active_goal",
    "token_budget",
    "provenance",
    "items"
  ],
  "properties": {
    "active_goal": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "items": {
      "type": "array",
      "items": {"$ref": "#/definitions/contextItem"}
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["broad_context_id", "full_trace_pointer"],
      "properties": {
        "broad_context_id": {"type": "string", "minLength": 1},
        "full_trace_pointer": {"type": "string", "minLength": 1}
      }
    },
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "token_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_max", "estimated_used"],
      "properties": {
        "estimated_used": {"type": "integer", "minimum": 0},
        "target_max": {"type": "integer", "minimum": 1}
      }
    }
  },
  "definitions": {
    "contextItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "id",
        "priority",
        "source_refs",
        "summary_compact",
        "summary_human",
        "superseded_by",
        "supersedes",
        "tags",
        "type",
        "valid_from",
        "valid_to"
      ],
      "properties": {
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-:.]*$"},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
        "source_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "summary_compact": {"type": "string", "minLength": 1, "maxLength": 280},
        "summary_human": {"type": "string", "minLength": 1},
        "superseded_by": {"type": ["string", "null"]},
        "supersedes": {"type": ["string", "null"]},
        "tags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "type": {
          "type": "string",
          "enum": ["decision", "task", "artifact", "risk", "dependency", "note", "incident"]
        },
        "valid_from": {"type": "string", "format": "date-time"},
        "valid_to": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
