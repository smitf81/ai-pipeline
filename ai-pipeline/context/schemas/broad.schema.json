{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-pipeline.local/context/schemas/broad.schema.json",
  "title": "Broad Context Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_id",
    "generated_at",
    "project",
    "token_budget",
    "architecture",
    "items",
    "open_decisions",
    "roadmap"
  ],
  "properties": {
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules"],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "purpose"],
            "properties": {
              "name": {"type": "string"},
              "path": {"type": "string"},
              "purpose": {"type": "string"}
            }
          }
        }
      }
    },
    "context_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "items": {
      "type": "array",
      "items": {"$ref": "#/definitions/contextItem"}
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "question", "target_date", "status"],
        "properties": {
          "id": {"type": "string"},
          "owner": {"type": "string"},
          "question": {"type": "string"},
          "status": {"type": "string", "enum": ["open", "resolved", "deferred"]},
          "target_date": {"type": "string", "format": "date"}
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repository_root", "summary"],
      "properties": {
        "name": {"type": "string"},
        "repository_root": {"type": "string"},
        "summary": {"type": "string"}
      }
    },
    "roadmap": {
      "type": "array",
      "items": {"type": "string"}
    },
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "token_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_soft_max", "estimated_used"],
      "properties": {
        "estimated_used": {"type": "integer", "minimum": 0},
        "target_soft_max": {"type": "integer", "minimum": 1}
      }
    }
  },
  "definitions": {
    "contextItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "id",
        "priority",
        "source_refs",
        "summary_compact",
        "summary_human",
        "superseded_by",
        "supersedes",
        "tags",
        "type",
        "valid_from",
        "valid_to"
      ],
      "properties": {
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-:.]*$"},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
        "source_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "summary_compact": {"type": "string", "minLength": 1, "maxLength": 280},
        "summary_human": {"type": "string", "minLength": 1},
        "superseded_by": {"type": ["string", "null"]},
        "supersedes": {"type": ["string", "null"]},
        "tags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "type": {
          "type": "string",
          "enum": ["decision", "task", "artifact", "risk", "dependency", "note", "incident"]
        },
        "valid_from": {"type": "string", "format": "date-time"},
        "valid_to": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
