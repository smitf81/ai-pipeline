```python
def start_watcher(py, watcher, project, content, log, lock):
    args = [sys.executable, str(watcher), 
            f"--bridge={project}", f"--content={content}", 
            f"--log={log}", f"--lock={lock}"]
    process = subprocess.Popen(args, creationflags=subprocess.CREATE_NEW_PROCESS_GROUP)
    return process
```
