def _save_state(self):
    state_file = Path(self.bridge_dir) / "state.json"
    state_file.parent.mkdir(parents=True, exist_ok=True)
    with open(state_file, 'w') as f:
        json.dump({'imported': list(self._state['imported'])}, f)
