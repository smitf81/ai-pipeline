3. Replace the `start()` method in the `bridge_watcher.py` file with the following:
```python
def start(self):
    if self._handle is not None:
        print("Already running.")
        return
    self._ensure_dest()
    self._handle = unreal.register_slate_post_tick_callback(self._tick)
    print("Watching:", self.bridge_dir)
    print("Dest:", self.content_path)
    print("Poll every %ss (non-blocking)." % self.poll_seconds)
    if not Path(self.bridge_dir / "state.json").exists():
        self._load_state()
    unreal.slate_run_async(
        lambda: threading.Timer(0, self._save_state).start(),
        None, 
        unreal.SlateRunAsyncFlags.SLATE_RUN_ASYNC_NO_TIMEOUT
    )
```
4. Add a new method called `_load_state` in the `bridge_watcher.py` file:
```python
def _load_state(self):
    state_file = Path(self.bridge_dir) / "state.json"
    if not state_file.exists():
        return
    with open(state_file, 'r') as f:
        data = json.load(f)
    self._state['imported'] = set(data['imported'])
```
