def test_start_watcher_persistent(tmp_path):
    project = tmp_path
    content = tmp_path / "Content"
    log = tmp_path / "log.txt"
    lock = tmp_path / "watch.lock"
    bridge_dir = tmp_path / "bridge"

    state_file = bridge_dir / "state.json"
    state_file.write_text('{"imported": ["test1.fbx", "test2.fbx"]}')

    with mock.patch("subprocess.Popen") as popen:
        watcher = send_to_unreal_bridge.ue_python.bridge_autostart.BridgeWatcher(project, content, log, lock, bridge_dir)
        assert not popen.called
        watcher.start()
        popen.assert_called_once_with([sys.executable, str(bridge_dir / "bridge_watcher.py"),
                                       f"--bridge={bridge_dir}", f"--content={content}", 
                                       f"--log={log}", f"--lock={lock}"], 
                                      creationflags=subprocess.CREATE_NEW_PROCESS_GROUP)
```
