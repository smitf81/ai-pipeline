{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ace.local/schemas/ta/candidate-profile.json",
  "title": "CandidateProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "role",
    "department",
    "desk_targets",
    "primary_desk_target",
    "assigned_model",
    "model_locked",
    "summary",
    "strengths",
    "weaknesses",
    "recommended_tools",
    "recommended_skills",
    "model_policy",
    "why_this_role",
    "risk_notes",
    "confidence",
    "cv_card",
    "contract"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "department": {
      "type": "string",
      "minLength": 1
    },
    "desk_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_desk_target": {
      "type": "string",
      "minLength": 1
    },
    "assigned_model": {
      "type": "string",
      "minLength": 1
    },
    "model_locked": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferred",
        "reason"
      ],
      "properties": {
        "preferred": {
          "type": "string",
          "enum": [
            "local",
            "codex",
            "hybrid"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "why_this_role": {
      "type": "string",
      "minLength": 1
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "cv_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "headline",
        "summary",
        "evidence",
        "controls",
        "contract"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input",
            "output"
          ],
          "properties": {
            "input": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "output": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "output"
      ],
      "properties": {
        "input": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
