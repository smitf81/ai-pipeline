{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ace.local/schemas/shared-artifact.schema.json",
  "title": "ACE Shared Artifact",
  "type": "object",
  "required": [
    "artifact_type",
    "id",
    "data",
    "dependencies",
    "parameters",
    "meta"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "material",
        "blueprint",
        "ai_behaviour",
        "animation_controller",
        "state_machine",
        "sprite_sheet"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_\\-]+$"
    },
    "data": {
      "type": "object"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "default": {}
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["author", "created_at", "engine_target"],
      "properties": {
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "engine_target": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
