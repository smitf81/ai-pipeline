{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ace.local/schemas/base-module.schema.json",
  "title": "ACE Base Module",
  "type": "object",
  "required": [
    "module_id",
    "version",
    "input",
    "pipeline",
    "output",
    "confidence",
    "requires_human_review"
  ],
  "properties": {
    "module_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "input": {
      "type": "object",
      "required": ["intent", "constraints", "context"],
      "properties": {
        "intent": { "type": "object" },
        "constraints": { "type": "object" },
        "context": { "type": "object" }
      },
      "additionalProperties": false
    },
    "pipeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "description"],
        "properties": {
          "step": {
            "type": "string",
            "enum": ["plan", "generate", "refine", "validate", "export"]
          },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "allOf": [
        { "contains": { "type": "object", "properties": { "step": { "const": "plan" } }, "required": ["step"] } },
        { "contains": { "type": "object", "properties": { "step": { "const": "generate" } }, "required": ["step"] } },
        { "contains": { "type": "object", "properties": { "step": { "const": "refine" } }, "required": ["step"] } },
        { "contains": { "type": "object", "properties": { "step": { "const": "validate" } }, "required": ["step"] } },
        { "contains": { "type": "object", "properties": { "step": { "const": "export" } }, "required": ["step"] } }
      ]
    },
    "output": {
      "type": "object",
      "required": ["artifact", "metadata", "validation"],
      "properties": {
        "artifact": { "type": "object" },
        "metadata": { "type": "object" },
        "validation": { "$ref": "#/defs/validationResult" }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "requires_human_review": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "defs": {
    "validationResult": {
      "type": "object",
      "required": ["checks", "status"],
      "properties": {
        "checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
